rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable Global Security Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && (
        request.auth.uid == userId || 
        (request.auth.token.email != null && request.auth.token.email.lower() == userId.lower())
      );
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email != null &&
             request.auth.token.email.matches('(?i)^veira1x1@gmail\\.com$');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Data Verification Helpers
    function isValidClientAccount(data) {
      return data.name is string 
          && data.email is string
          && data.credits is number && data.credits >= 0;
    }

    function isValidCVProfile(data) {
      return data.fullName is string;
    }

    // A robust, simplified voucher check that doesn't brick if optional metadata fields are updated or omitted
    function isValidVoucher(data) {
      return data.value is number && data.value >= 0
          && data.active is bool;
    }

    function isValidAppConfig(data) {
      return data.appName is string && data.appName.size() <= 256;
    }

    // Rules matching resources in the Firebase blueprint
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if (isOwner(userId) && isValidClientAccount(incoming())) || isAdmin();
      allow update: if (isOwner(userId) && isValidClientAccount(incoming())) || isAdmin();
      allow delete: if isAdmin();

      // Subcollection for client-owned resumes
      match /resumes/{resumeId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidId(resumeId) && isValidCVProfile(incoming());
        allow update: if isOwner(userId) && isValidCVProfile(incoming());
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    match /vouchers/{voucherCode} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isAdmin() && isValidId(voucherCode) && isValidVoucher(incoming());
      allow update: if isSignedIn() && isValidVoucher(incoming());
      allow delete: if isAdmin();
    }

    match /codes/{codeId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isAdmin() && isValidId(codeId);
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin() && isValidAppConfig(incoming());
    }
  }
}
